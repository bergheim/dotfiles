// niri config — mirrors stash/swayr/config (sway).
// Install at ~/.config/niri/config.kdl on the host.
//
// === Sway bindings that do NOT translate, with reasons ===
//
//   $mod+$alt+BackSpace   mode "xkill"
//                         niri has no input modes. Use Mod+Shift+BackSpace
//                         (force-kill focused PID) below.
//   $mod+x                layout toggle tabbed splitv splith
//                         niri columns are 1D; only tabbed display exists,
//                         and that's on Mod+D.
//   $mod+s                layout stacking
//                         No stacking layout. Tabbed display is the closest.
//   $mod+shift+s          focus parent
//   $mod+shift+d          focus child
//                         No container hierarchy: columns have no parents.
//   $mod+ctrl+s           split horizontal; layout stacking
//   $mod+ctrl+d           split vertical; layout tabbed
//   $mod+\                split toggle
//                         No splits — niri has columns and floating only.
//                         Use Mod+BracketLeft/Right (consume-or-expel-window)
//                         and Mod+D (toggle tabbed) to compose layouts.
//   $mod+a                [urgent=latest] focus
//                         No focus-urgent action. Urgent windows show via
//                         the urgent-color border on the focus ring.
//   $mod+grave            scratchpad show
//                         No scratchpad concept in niri. Closest: a window
//                         rule with open-floating + a key that spawn-sh's
//                         the app, but no hide/show toggle exists.
//   $mod+i                mode "resize"
//                         No input modes. Direct resize binds preserved on
//                         $mod+$alt+hjkl.
//   $mod+shift+f          fullscreen disable; floating toggle; resize 1920 1080;
//                         move position center; sticky enable
//                         niri has no sticky-across-workspaces. The float +
//                         resize part is reachable via $mod+$alt+f and
//                         set-window-width/height, but not as one bind.
//                         Left unbound — pick a niri-native sequence later.
//   $mod+Shift+g          mode "$mode_gaps"   (and the +/- gap presets)
//   $mod+minus/equal      gap presets
//   $mod+shift+minus/eq.  gap presets
//                         niri gaps are global, not per-workspace, and have
//                         no runtime adjustment binds.
//   $alt+b                border toggle
//                         No per-window border toggle. Configure globally in
//                         the layout {} block.
//   XF86TouchpadToggle/On/Off
//                         No runtime input-device enable/disable action.
//   floating_modifier $mod (Mod+drag to move/resize floats)
//                         niri supports this via move-window-with-mouse and
//                         resize-window-with-mouse, but the mouse-button bind
//                         syntax varies by version — added below as a TODO
//                         the user can verify.
//
// === Niri-essential binds NOT in sway, but kept because the column model ===
// === can't be operated without them ===
//
//   Mod+BracketLeft/Right consume-or-expel-window (move window into/out of column)
//   Mod+Comma/Period      consume/expel-window-into-column (single-window variant)
//   Mod+M                 inline fuzzel window switcher + app icons (swayr LRU)
//   Alt+Tab               toggle-overview
//   Mod+Space             NOT a niri bind — xkb grp:win_space_toggle (us↔no)

input {
    keyboard {
        xkb {
            layout "us,no"
            variant "altgr-intl"
            options "grp:win_space_toggle,caps:escape"
        }
        repeat-rate 50
        repeat-delay 180
        numlock
    }

    touchpad {
        tap
        dwt
        natural-scroll
        middle-emulation
    }

    mouse {}
    trackpoint {}
}

// Outputs: run `niri msg outputs` once running, then fill in modes.
// Workspace model is hybrid: ws 1-6 named/persistent (identity + app
// routing + stable waybar icons); 7+ dynamic. Output pins removed —
// the single-display laptop never used them and niri keeps workspaces
// per-output without them.
//
// /-output "DP-0" {
//     mode "..."
//     scale 1
//     position x=0 y=0
// }
// /-output "DP-2" {
//     mode "..."
//     scale 1
//     position x=1920 y=0
// }

// Hybrid model: only 1-6 are NAMED (persistent) — they carry identity,
// app routing (see open-on-workspace rules), and stable waybar icons.
// 7+ are dynamic: created on demand, hidden by waybar hide-empty when
// empty (sway-like).
//
// Docking (i3-style fixed split): the six main workspaces are pinned to the
// external via open-on-output, keyed on the CONNECTOR "DP-2" (the office
// dock port) rather than the monitor's make/model — so any monitor on that
// port gets the layout, and it survives reboot (no manual re-arranging).
// When DP-2 connects, niri moves 1-6 (and their windows) onto it; when it
// disconnects they fall back to the only output (laptop eDP-1) and return on
// reconnect. The number-key workspaces (4/5/6 -> dynamic 7/8/9) stay on the
// laptop. niri also remembers any runtime move (move-workspace-to-monitor
// updates a workspace's home output) for the rest of the session.
workspace "1" { open-on-output "DP-2"; }   // browser (firefox)
workspace "2" { open-on-output "DP-2"; }   // chat (Telegram/Discord/Slack/Element)
workspace "3" { open-on-output "DP-2"; }   // music (Spotify)
workspace "4" { open-on-output "DP-2"; }   // email (Chromium)
workspace "5" { open-on-output "DP-2"; }   // emacs
workspace "6" { open-on-output "DP-2"; }   // emacs

layout {
    gaps 10
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    // Gruvbox-light, matching $c10 / $bg / $c1 from the sway colors block.
    focus-ring {
        width 2
        active-color "#c0df6f"
        inactive-color "#1d2021"
    }

    border {
        off
        width 1
        active-color "#c0df6f"
        inactive-color "#1d2021"
        urgent-color "#cc241d"
    }

    tab-indicator {
        hide-when-single-tab          // no strip when a column has one window
        place-within-column           // strip eats column space instead of overlapping the gap
        gap 5
        width 4
        position "right"
        gaps-between-tabs 2
        corner-radius 8
        // Static, theme-agnostic: niri config can't switch per
        // light/dark (Super+F1 only retints waybar/GTK, not niri).
        // #b8bb26 = Gruvbox bright green — legible as a thin strip on
        // BOTH backgrounds; the theme focus_bg greens (#086608 dark /
        // #c0df6f light) are background tints, too low-contrast here.
        active-color "#b8bb26"
        inactive-color "#1d2021"
        urgent-color "#cc241d"
    }

    shadow {
        on
        softness 10
        spread 0
        offset x=0 y=5
        color "#00000080"
    }

    struts {}
}

// opacity 0.8 (swayfx for_window [class=".*"] opacity 0.8)
// + default_dim_inactive 0.1 → active 1.0, inactive 0.9
window-rule {
    opacity 0.9
    // Rounded corners for all windows. Both keys are required:
    // geometry-corner-radius alone only rounds the border/focus-ring;
    // clip-to-geometry actually clips the window content to the shape.
    geometry-corner-radius 10
    clip-to-geometry true
}
window-rule {
    match is-active=true
    opacity 1.0
}

// Floating rules from sway.
window-rule {
    match app-id=r#"^qalculate-gtk$"#
    open-floating true
}
window-rule {
    match title="^Microsoft Teams Notification$"
    open-floating true
}
window-rule {
    match app-id="Emacs" title="emacs-everywhere"
    open-floating true
}
window-rule {
    match app-id=r#"^gnome-calendar$"#
    open-floating true
}
window-rule {
    match title="^emacs-float$"
    open-floating true
    default-column-width { fixed 800; }
}
window-rule {
    match app-id=r#"^floating"#
    open-floating true
}
window-rule {
    match title="^floating"
    open-floating true
}
window-rule {
    match title="Picture-in-Picture"
    open-floating true
}

// Auto-place on workspaces (sway "assign" + for_window move to workspace).
window-rule {
    match app-id=r#"^TelegramDesktop$"#
    open-on-workspace "2"
}
window-rule {
    match app-id="Spotify"
    open-on-workspace "3"
}
window-rule {
    match app-id=r#"^discord$"#
    open-on-workspace "2"
}
window-rule {
    match app-id="Slack"
    open-on-workspace "2"
}
window-rule {
    match app-id=r#"^Element"#
    open-on-workspace "2"
}
window-rule {
    match app-id=r#"^Chromium$"#
    open-on-workspace "4"
}

layer-rule {
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}

spawn-sh-at-startup "systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP"
spawn-sh-at-startup "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=niri"
spawn-at-startup "systemctl" "--user" "start" "emacs.service"
spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "swayosd-server"
spawn-at-startup "kanshi"
spawn-at-startup "swaybg" "-i" "/home/tsb/Pictures/wallpapers/active/light/primary.jpg" "-m" "fill"
spawn-sh-at-startup "wl-paste --watch cliphist store"
spawn-sh-at-startup "swayidle -w timeout 300 'fancylocksway' timeout 600 'niri msg action power-off-monitors' timeout 1800 'systemctl suspend-then-hibernate' before-sleep 'fancylocksway' lock 'fancylocksway'"

prefer-no-csd

screenshot-path "~/Pictures/screenshots/%Y%m%dT%H%M%S--screenshot-local__.png"

hotkey-overlay {
    skip-at-startup
}

binds {
    // Mod = Super on TTY. Alt+ = Mod1 / sway's $alt.

    Mod+Shift+F { maximize-column; }


    // -- Apps & launchers (sway lines 268, 272, 278, 281–283, 361, 364, 372, 375) --
    Mod+Shift+Return       { spawn "ghostty"; }
    Mod+Return             { spawn "emacsclient" "-nc"; }
    Mod+R                  { spawn "fuzzel"; }
    Mod+P                  { spawn "fuzzel-pass"; }
    Mod+V                  { spawn-sh "cliphist list | fuzzel -d | cliphist decode | wl-copy"; }
    Mod+Shift+E            { spawn-sh "BEMOJI_PICKER_CMD='fuzzel -d' bemoji"; }
    Mod+Z                  { spawn "emacsclient" "--eval" "(emacs-everywhere)"; }
    Mod+C                  { spawn "emacs-capture" "--eval" "(bergheim/capture)"; }
    Mod+T                  { spawn "emacs-clock-in"; }
    Mod+O                  { spawn "emacsclient" "--eval" "(thanos/type)" "-F" "((name . \"floating\"))"; }
    Mod+Escape             { spawn "fancylocksway"; }
    Mod+F1                 { spawn "toggle-darkmode"; }
    Mod+F2                 { spawn-sh "(pkill gammastep && notify-send 'Disabling color temperature') || (notify-send 'Enabling color temperature' && gammastep)"; }
    Mod+F5                 { spawn "alacritty" "--class" "floating" "-e" "impala"; }
    Mod+F12                { spawn-sh "journalctl --user -u niri -n 100 > /tmp/niri-debug.log && notify-send 'Niri log dumped'"; }

    // sway 367–368 (swayr LRU switcher). Mod+Space is intentionally NOT bound
    // here — xkb grp:win_space_toggle owns it for us↔no layout switching, and a
    // niri bind shadows that. Do not re-add Mod+Space. Window switcher
    // is Mod+M — INLINE on purpose: no external script / host-install
    // dependency (a script broke once because it wasn't on PATH). fuzzel
    // + app icons via the NUL icon protocol built with printf; the id
    // rides a trailing tab field and awk recovers it. Overview: Alt+Tab.
    Mod+M     repeat=false { spawn-sh "T=$(printf '\\t'); niri msg --json windows | jq -r '.[] | [.title, .id, .app_id] | @tsv' | while IFS= read -r L; do printf '%s\\0icon\\037%s\\n' \"${L%${T}*}\" \"${L##*${T}}\"; done | fuzzel --dmenu --prompt 'window: ' | awk -F'\\t' '{print $NF}' | xargs -r niri msg action focus-window --id"; }
    Alt+Tab   repeat=false { toggle-overview; }

    // -- Notifications, mako (sway lines 378–381) --
    Mod+Ctrl+Grave         { spawn "makoctl" "dismiss"; }
    Mod+Ctrl+1             { spawn "makoctl" "restore"; }
    Mod+Ctrl+3             { spawn "makoctl" "dismiss" "--all"; }
    Mod+Ctrl+2             { spawn-sh "makoctl menu -- fuzzel -d -p 'Select action:'"; }

    // -- Window management (sway lines 108, 142, 145, 162, 176, 286) --
    Mod+BackSpace          { close-window; }
    Mod+Shift+BackSpace    { spawn-sh "PID=$(niri msg --json focused-window 2>/dev/null | jq -r '.pid // empty'); [ -n \"$PID\" ] && kill -9 \"$PID\""; }
    Mod+F                  { fullscreen-window; }
    Mod+Alt+F              { toggle-window-floating; }
    Mod+D                  { toggle-column-tabbed-display; }   // sway: layout tabbed
    Mod+Shift+Space        { switch-focus-between-floating-and-tiling; }   // sway: focus mode_toggle

    // niri-essential column manipulation (no sway equivalent — see header).
    Mod+BracketLeft        { consume-or-expel-window-left; }
    Mod+BracketRight       { consume-or-expel-window-right; }
    Mod+Comma              { consume-window-into-column; }
    Mod+Period             { expel-window-from-column; }

    // -- Focus, hjkl + arrows (sway lines 118–127) --
    // j/k use *-or-workspace: navigate windows within a column, and at
    // the column edge fall through to the next/prev workspace (vim-key
    // parity with h/l moving between columns; works in the overview too).
    // Workspace-only jumps remain on Mod+Ctrl+H/L and Mod+Tab.
    Mod+H        { focus-column-left; }
    Mod+J        { focus-window-or-workspace-down; }
    Mod+K        { focus-window-or-workspace-up; }
    Mod+L        { focus-column-right; }
    Mod+Left     { focus-column-left; }
    Mod+Down     { focus-window-or-workspace-down; }
    Mod+Up       { focus-window-or-workspace-up; }
    Mod+Right    { focus-column-right; }

    // -- Move (sway lines 130–139) --
    // j/k use *-or-to-workspace: move the window within the column, and
    // at the column edge carry it to the next/prev workspace (symmetry
    // with the focus j/k -or-workspace binds above).
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+J     { move-window-down-or-to-workspace-down; }
    Mod+Shift+K     { move-window-up-or-to-workspace-up; }
    Mod+Shift+L     { move-column-right; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Down  { move-window-down-or-to-workspace-down; }
    Mod+Shift+Up    { move-window-up-or-to-workspace-up; }
    Mod+Shift+Right { move-column-right; }

    // -- Resize, $mod+$alt+hjkl (sway lines 257–265) --
    Mod+Alt+L         { set-column-width "+10%"; }
    Mod+Alt+H         { set-column-width "-10%"; }
    Mod+Alt+Shift+L   { set-column-width "-10%"; }
    Mod+Alt+Shift+H   { set-column-width "+10%"; }
    Mod+Alt+J         { set-window-height "+10%"; }
    Mod+Alt+K         { set-window-height "-10%"; }
    Mod+Alt+Shift+J   { set-window-height "-10%"; }
    Mod+Alt+Shift+K   { set-window-height "+10%"; }

    // -- Workspaces (sway lines 205–217) --
    Mod+1 { focus-workspace "1"; }
    Mod+2 { focus-workspace "2"; }
    Mod+3 { focus-workspace "3"; }
    Mod+Q { focus-workspace "4"; }
    Mod+W { focus-workspace "5"; }
    Mod+E { focus-workspace "6"; }
    // 7+ dynamic: unquoted index navigates positionally and never
    // creates a named (persistent) workspace. Quoted "1".."6" above
    // are named refs on purpose — leave them quoted.
    Mod+4 { focus-workspace 7; }
    Mod+5 { focus-workspace 8; }
    Mod+6 { focus-workspace 9; }
    Mod+7 { focus-workspace 10; }
    Mod+8 { focus-workspace 11; }
    Mod+9 { focus-workspace 12; }
    Mod+0 { focus-workspace 13; }

    // Move column to workspace (sway lines 220–232).
    Mod+Alt+1 { move-column-to-workspace "1"; }
    Mod+Alt+2 { move-column-to-workspace "2"; }
    Mod+Alt+3 { move-column-to-workspace "3"; }
    Mod+Alt+Q { move-column-to-workspace "4"; }
    Mod+Alt+W { move-column-to-workspace "5"; }
    Mod+Alt+E { move-column-to-workspace "6"; }
    // 7+ dynamic: unquoted index (see focus-workspace note above).
    Mod+Alt+4 { move-column-to-workspace 7; }
    Mod+Alt+5 { move-column-to-workspace 8; }
    Mod+Alt+6 { move-column-to-workspace 9; }
    Mod+Alt+7 { move-column-to-workspace 10; }
    Mod+Alt+8 { move-column-to-workspace 11; }
    Mod+Alt+9 { move-column-to-workspace 12; }
    Mod+Alt+0 { move-column-to-workspace 13; }

    // back_and_forth + workspace next/prev (sway lines 179–181).
    Mod+Tab     { focus-workspace-previous; }
    Mod+Ctrl+L  { focus-workspace-down; }
    Mod+Ctrl+H  { focus-workspace-up; }

    // -- Monitors (sway lines 189, 191) --
    // -next/-previous cycle through all monitors regardless of their
    // left/right position, so SUPER+N always switches with 2 displays
    // (the old -right was a no-op from whichever monitor was rightmost).
    Mod+N        { focus-monitor-next; }            // focus the other monitor
    Mod+Shift+N  { move-workspace-to-monitor-next; } // send THIS workspace over

    // -- Screenshots (sway lines 298–299) --
    // Sway uses grimshot (sway-only) + a custom thumbnail/upload pipeline.
    // niri's built-ins don't replicate that; bind the closest niri actions and
    // add upload/thumbnail scripts later if desired.
    Print        { screenshot-window; }   // sway: grimshot save active
    Shift+Print  { screenshot; }          // sway: grimshot save anything (+ upload)

    // -- Recording (sway lines 313, 315, 316) --
    // record-sway likely uses swaymsg internally; you'll need a niri-aware
    // version (record-niri?) for window/region selection.
    Mod+Shift+R  { spawn "record-sway"; }
    Mod+Shift+W  { spawn "record-sway" "window"; }
    Mod+Shift+T  { spawn-sh "pkill -INT wf-recorder && notify-send 'Wayland WebP Record' 'Recording stopped.'"; }

    // -- System (sway lines 78, 309, 386, 390, 407) --
    Mod+Shift+C       { spawn-sh "niri msg action load-config-file"; }   // sway: reload
    Mod+F6            { spawn-sh "niri msg action load-config-file"; }   // sway: F6 reload
    Mod+Alt+Escape    { spawn-sh "niri msg action load-config-file"; }   // sway: $mod+$alt+Escape restart
    Mod+Shift+Q       { spawn-sh "ACT=$(printf 'lock\\nlogout\\nsuspend\\nreboot\\nshutdown\\nuefi' | fuzzel -d -p 'system: '); case \"$ACT\" in lock) fancylocksway;; logout) niri msg action quit;; suspend) systemctl suspend;; reboot) systemctl reboot;; shutdown) systemctl poweroff -i;; uefi) systemctl reboot --firmware-setup;; esac"; }
    Ctrl+Alt+Delete   { spawn-sh "[ \"$(printf 'NO\\nYES' | fuzzel -d -p 'Really restart system? ')\" = YES ] && restart-system"; }

    // -- Audio / brightness, swayosd-client (sway lines 347–358) --
    XF86AudioRaiseVolume   allow-when-locked=true { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume   allow-when-locked=true { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute          allow-when-locked=true { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    XF86AudioMicMute       allow-when-locked=true { spawn "swayosd-client" "--input-volume" "mute-toggle"; }
    XF86MonBrightnessUp    allow-when-locked=true { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown  allow-when-locked=true { spawn "swayosd-client" "--brightness" "lower"; }

    // niri convention: hotkey overlay.
    Mod+Shift+Slash { show-hotkey-overlay; }
}