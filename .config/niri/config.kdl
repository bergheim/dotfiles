// niri config — mirrors the sway setup at stash/swayr/config.
// Install at ~/.config/niri/config.kdl on the host.
//
// Notes on what does NOT translate from sway:
//   - i3 container layouts ($mod+s/d/x, split, focus parent/child, $mod+\):
//     niri is column-scrolling; closest analogs are toggle-column-tabbed-display
//     and consume/expel-window. Old binds left unbound — repurpose if useful.
//   - xkill mode, resize mode, gaps mode: niri has no input modes. Use direct
//     binds (resize binds preserved as $mod+$alt+hjkl) or skip.
//   - Scratchpad ($mod+grave): niri has no scratchpad concept.
//   - swayfx blur: not supported in niri. Shadows are supported.
//   - Wallpaper: niri does not paint a background, swaybg is launched at startup.
//   - swayr LRU window switcher: no built-in equivalent. Use the overview
//     ($mod+o) or fuzzel-via-niri-msg as a stopgap.

input {
    keyboard {
        xkb {
            layout "us,no"
            variant "altgr-intl"
            options "grp:win_space_toggle,caps:escape"
        }
        repeat-rate 50
        repeat-delay 180
        numlock
    }

    touchpad {
        tap
        dwt
        natural-scroll
        middle-emulation
    }

    mouse {}
    trackpoint {}
}

// Outputs: run `niri msg outputs` once running, then fill in modes.
// The sway config places workspaces 1–9 on DP-0 and 10–13 on DP-2;
// the named-workspace blocks below pin them to those outputs.
//
// /-output "DP-0" {
//     mode "..."
//     scale 1
//     position x=0 y=0
// }
// /-output "DP-2" {
//     mode "..."
//     scale 1
//     position x=1920 y=0
// }

// Persistent named workspaces, matching the sway slots.
workspace "1"  { open-on-output "DP-0"; }   // firefox
workspace "2"  { open-on-output "DP-0"; }   // chat
workspace "3"  { open-on-output "DP-0"; }   // music
workspace "4"  { open-on-output "DP-0"; }   // email
workspace "5"  { open-on-output "DP-0"; }   // emacs
workspace "6"  { open-on-output "DP-0"; }   // emacs
workspace "7"  { open-on-output "DP-0"; }
workspace "8"  { open-on-output "DP-0"; }
workspace "9"  { open-on-output "DP-0"; }
workspace "10" { open-on-output "DP-2"; }
workspace "11" { open-on-output "DP-2"; }
workspace "12" { open-on-output "DP-2"; }
workspace "13" { open-on-output "DP-2"; }

layout {
    gaps 10
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    // Gruvbox-light focus ring, matching $c10 / $bg from the sway colors block.
    focus-ring {
        width 2
        active-color "#c0df6f"
        inactive-color "#1d2021"
    }

    border {
        off
        width 1
        active-color "#c0df6f"
        inactive-color "#1d2021"
        urgent-color "#cc241d"
    }

    shadow {
        on
        softness 10
        spread 0
        offset x=0 y=5
        color "#00000080"
    }

    struts {}
}

// Window opacity 0.8 like the swayfx for_window [class=".*"] opacity 0.8.
// Active=1.0, inactive=0.9 approximates default_dim_inactive 0.1.
window-rule {
    opacity 0.9
}
window-rule {
    match is-active=true
    opacity 1.0
}

// Floating rules from sway.
window-rule {
    match app-id=r#"^qalculate-gtk$"#
    open-floating true
}
window-rule {
    match title="^Microsoft Teams Notification$"
    open-floating true
}
window-rule {
    match app-id="Emacs" title="emacs-everywhere"
    open-floating true
}
window-rule {
    match app-id=r#"^gnome-calendar$"#
    open-floating true
}
window-rule {
    match title="^emacs-float$"
    open-floating true
    default-column-width { fixed 800; }
}
window-rule {
    match app-id=r#"^floating"#
    open-floating true
}
window-rule {
    match title="^floating"
    open-floating true
}
window-rule {
    match title="Picture-in-Picture"
    open-floating true
}

// Auto-place windows on workspaces (sway "assign" + "for_window move to workspace").
window-rule {
    match app-id=r#"^TelegramDesktop$"#
    open-on-workspace "2"
}
window-rule {
    match app-id="Spotify"
    open-on-workspace "3"
}
window-rule {
    match app-id=r#"^discord$"#
    open-on-workspace "2"
}
window-rule {
    match app-id="Slack"
    open-on-workspace "2"
}
window-rule {
    match app-id=r#"^Element"#
    open-on-workspace "2"
}
window-rule {
    match app-id=r#"^Chromium$"#
    open-on-workspace "4"
}

// Startup. systemctl --user import-environment is handled by niri's session unit;
// listed here for parity with the sway config's exec lines.
spawn-sh-at-startup "systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP"
spawn-sh-at-startup "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=niri"
spawn-at-startup "systemctl" "--user" "start" "emacs.service"
spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "swayosd-server"
spawn-at-startup "kanshi"
spawn-at-startup "swaybg" "-i" "/home/tsb/Pictures/wallpapers/active/light/primary.jpg" "-m" "fill"
spawn-sh-at-startup "wl-paste --watch cliphist store"
spawn-sh-at-startup "swayidle -w timeout 300 'fancylocksway' timeout 600 'niri msg action power-off-monitors' timeout 1800 'systemctl suspend-then-hibernate' before-sleep 'fancylocksway' lock 'fancylocksway'"

prefer-no-csd

screenshot-path "~/Pictures/screenshots/%Y%m%dT%H%M%S--screenshot-local__.png"

hotkey-overlay {
    skip-at-startup
}

binds {
    // Mod = Super on TTY, Alt-as-second-mod is just Alt+ in niri syntax.

    // -- Apps & launchers --
    Mod+Shift+Return       { spawn "ghostty"; }
    Mod+Return             { spawn "emacsclient" "-nc"; }
    Mod+R                  { spawn "fuzzel"; }
    Mod+P                  { spawn "fuzzel-pass"; }
    Mod+V                  { spawn-sh "cliphist list | fuzzel -d | cliphist decode | wl-copy"; }
    Mod+Shift+E            { spawn-sh "BEMOJI_PICKER_CMD='fuzzel -d' bemoji"; }
    Mod+Z                  { spawn "emacsclient" "--eval" "(emacs-everywhere)"; }
    Mod+C                  { spawn "emacs-capture" "--eval" "(bergheim/capture)"; }
    Mod+T                  { spawn "emacs-clock-in"; }
    Mod+O                  { spawn "emacsclient" "--eval" "(thanos/type)" "-F" "((name . \"floating\"))"; }
    Mod+Escape             { spawn "fancylocksway"; }
    Mod+F1                 { spawn "toggle-darkmode"; }
    Mod+F2                 { spawn-sh "(pkill gammastep && notify-send 'Disabling color temperature') || (notify-send 'Enabling color temperature' && gammastep)"; }
    Mod+F5                 { spawn "alacritty" "--class" "floating" "-e" "impala"; }
    Mod+F12                { spawn-sh "journalctl --user -u niri -n 100 > /tmp/niri-debug.log && notify-send 'Niri log dumped'"; }

    // Replacement for swayr LRU switcher: niri overview.
    Mod+Space repeat=false { toggle-overview; }
    Alt+Tab   repeat=false { toggle-overview; }

    // -- Notifications (mako) --
    Mod+Ctrl+Grave         { spawn "makoctl" "dismiss"; }
    Mod+Ctrl+1             { spawn "makoctl" "restore"; }
    Mod+Ctrl+3             { spawn "makoctl" "dismiss" "--all"; }
    Mod+Ctrl+2             { spawn-sh "makoctl menu -- fuzzel -d -p 'Select action:'"; }

    // -- Window management --
    Mod+BackSpace          { close-window; }
    Mod+F                  { fullscreen-window; }
    Mod+Alt+F              { toggle-window-floating; }
    Mod+Shift+F            { maximize-column; }
    Mod+BracketLeft        { consume-or-expel-window-left; }
    Mod+BracketRight       { consume-or-expel-window-right; }
    Mod+Comma              { consume-window-into-column; }
    Mod+Period             { expel-window-from-column; }

    // -- Focus (hjkl + arrows) --
    Mod+H        { focus-column-left; }
    Mod+J        { focus-window-down; }
    Mod+K        { focus-window-up; }
    Mod+L        { focus-column-right; }
    Mod+Left     { focus-column-left; }
    Mod+Down     { focus-window-down; }
    Mod+Up       { focus-window-up; }
    Mod+Right    { focus-column-right; }

    // -- Move (Shift + focus) --
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+J     { move-window-down; }
    Mod+Shift+K     { move-window-up; }
    Mod+Shift+L     { move-column-right; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Down  { move-window-down; }
    Mod+Shift+Up    { move-window-up; }
    Mod+Shift+Right { move-column-right; }

    // -- Resize (Mod+Alt+hjkl, with Shift to shrink) --
    Mod+Alt+L         { set-column-width "+10%"; }
    Mod+Alt+H         { set-column-width "-10%"; }
    Mod+Alt+Shift+L   { set-column-width "-10%"; }
    Mod+Alt+Shift+H   { set-column-width "+10%"; }
    Mod+Alt+J         { set-window-height "+10%"; }
    Mod+Alt+K         { set-window-height "-10%"; }
    Mod+Alt+Shift+J   { set-window-height "-10%"; }
    Mod+Alt+Shift+K   { set-window-height "+10%"; }

    // -- Workspaces --
    Mod+1 { focus-workspace "1"; }
    Mod+2 { focus-workspace "2"; }
    Mod+3 { focus-workspace "3"; }
    Mod+Q { focus-workspace "4"; }
    Mod+W { focus-workspace "5"; }
    Mod+E { focus-workspace "6"; }
    Mod+4 { focus-workspace "7"; }
    Mod+5 { focus-workspace "8"; }
    Mod+6 { focus-workspace "9"; }
    Mod+7 { focus-workspace "10"; }
    Mod+8 { focus-workspace "11"; }
    Mod+9 { focus-workspace "12"; }
    Mod+0 { focus-workspace "13"; }

    Mod+Alt+1 { move-column-to-workspace "1"; }
    Mod+Alt+2 { move-column-to-workspace "2"; }
    Mod+Alt+3 { move-column-to-workspace "3"; }
    Mod+Alt+Q { move-column-to-workspace "4"; }
    Mod+Alt+W { move-column-to-workspace "5"; }
    Mod+Alt+E { move-column-to-workspace "6"; }
    Mod+Alt+4 { move-column-to-workspace "7"; }
    Mod+Alt+5 { move-column-to-workspace "8"; }
    Mod+Alt+6 { move-column-to-workspace "9"; }
    Mod+Alt+7 { move-column-to-workspace "10"; }
    Mod+Alt+8 { move-column-to-workspace "11"; }
    Mod+Alt+9 { move-column-to-workspace "12"; }
    Mod+Alt+0 { move-column-to-workspace "13"; }

    // back_and_forth + workspace next/prev.
    Mod+Tab     { focus-workspace-previous; }
    Mod+Ctrl+L  { focus-workspace-down; }
    Mod+Ctrl+H  { focus-workspace-up; }

    // -- Monitors --
    Mod+N        { focus-monitor-right; }
    Mod+Shift+N  { move-workspace-to-monitor-right; }

    // -- Screenshots --
    Print        { screenshot; }
    Ctrl+Print   { screenshot-screen; }
    Alt+Print    { screenshot-window; }

    // -- System --
    Mod+Shift+C       { spawn-sh "niri msg action load-config-file"; }
    Mod+Shift+Q       { spawn-sh "ACT=$(printf 'lock\\nlogout\\nsuspend\\nreboot\\nshutdown\\nuefi' | fuzzel -d -p 'system: '); case \"$ACT\" in lock) fancylocksway;; logout) niri msg action quit;; suspend) systemctl suspend;; reboot) systemctl reboot;; shutdown) systemctl poweroff -i;; uefi) systemctl reboot --firmware-setup;; esac"; }
    Ctrl+Alt+Delete   { spawn-sh "[ \"$(printf 'NO\\nYES' | fuzzel -d -p 'Really restart system? ')\" = YES ] && restart-system"; }
    Mod+Alt+Escape    { spawn-sh "niri msg action load-config-file"; }

    // -- Audio / brightness (swayosd-client, same as sway) --
    XF86AudioRaiseVolume   allow-when-locked=true { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume   allow-when-locked=true { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute          allow-when-locked=true { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    XF86AudioMicMute       allow-when-locked=true { spawn "swayosd-client" "--input-volume" "mute-toggle"; }
    XF86MonBrightnessUp    allow-when-locked=true { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown  allow-when-locked=true { spawn "swayosd-client" "--brightness" "lower"; }

    // -- Quit (with confirm dialog) --
    Mod+Shift+Slash { show-hotkey-overlay; }
}
