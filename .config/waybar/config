{
  /* Bar Settings */

    "id" : "bar",
    "layer": "top", // Waybar at top layer
    "position": "top",
    "height": 30,
    "spacing": 4,

    "modules-left": [
      // "custom/misc_menu",
      // sway/* render empty under niri and vice-versa; both kept for
      // dual sway+niri support. sway/scratchpad omitted (no niri equiv).
      "niri/workspaces",
      "sway/workspaces",
      "sway/mode"
    ],

    "modules-center": [
      "niri/window",
      "sway/window"
    ],

    "modules-right": [
      // "systemd-failed-units",
      // "idle_inhibitor",
      // "cpu",
      // "memory",
      // "temperature",
      "custom/weather",
      "mpris",
      // "pulseaudio",
      // "backlight",
      // "sway/language",
      "custom/gammastep",
      "battery",
      "custom/tux-power",
      // "power-profiles-daemon",
      "clock",
      // "keyboard-state",
