    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "¾░ê╣",      // firefox (browser)
            "2": "¾░¡╣",      // chat
            "3": "¾░ØÜ",      // music/spotify
            "4": "¾░ç«",      // email
            "5": "¾░ÜÇ",      // emacs
