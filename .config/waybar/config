            "12": "¾░ı╣",     // monitor2
            "13": "¾░ı╣",     // monitor2
            "urgent": "¾░Ç¬",
            // "focused": "¾░«»",
            "default": "¾░ğŞ"
        }
    },

    "sway/scratchpad": {
      "format": "[{count}]=",
      "show-empty": true,
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },

    "niri/window": {
      "format": "{title}",
