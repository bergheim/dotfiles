#!/usr/bin/env sh

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]; then
    # SSH session - use terminal, tag the frame for ssherpa routing
    emacsclient -a "" -t --eval '(ssherpa-connect)' "$@"
elif [ -n "$WAYLAND_DISPLAY" ] || [ -n "$DISPLAY" ]; then
    # GUI available (Sway, i3, or other)
    emacsclient -a "" -nc "$@"
else
    # Fallback to terminal (local tty)
    emacsclient -a "" -t "$@"
fi
