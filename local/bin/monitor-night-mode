#!/bin/env sh

# Night mode - dimmer, warmer, lower contrast

# Display 1 (27GN950)
ddcutil --display 1 setvcp 87 40 # lower sharpness for night (easier on eyes)
ddcutil --display 1 setvcp 10 20 # brightness
ddcutil --display 1 setvcp 12 50 # contrast
# Red tint for night
ddcutil --display 1 setvcp 16 60 # red
ddcutil --display 1 setvcp 18 40 # green
ddcutil --display 1 setvcp 1a 20 # blue
# Adjust black levels for warmer night look
# ddcutil --display 1 setvcp 6c 45   # red black level (reduce)
# ddcutil --display 1 setvcp 6e 50   # green black level (neutral)
# ddcutil --display 1 setvcp 70 55   # blue black level (increase for less blue in blacks)
# ddcutil --display 1 setvcp 14 0x0b # User 1 preset 9300K?

# Display 2 (27GL850)
ddcutil --display 2 setvcp 87 40 # sharpness
ddcutil --display 2 setvcp 10 0  # brightness
ddcutil --display 2 setvcp 12 50 # contrast
# Slight red tint for night
ddcutil --display 2 setvcp 16 35 # red (slight boost)
ddcutil --display 2 setvcp 18 28 # green (slight reduction)
ddcutil --display 2 setvcp 1a 0  # blue (more reduction)
# Reduce blue/cyan saturation for warmer look
ddcutil --display 2 setvcp 5c 45 # cyan saturation (reduce)
ddcutil --display 2 setvcp 5d 45 # blue saturation (reduce)

# Black levels
ddcutil --display 2 setvcp 6c 35   # red black level (reduce)
ddcutil --display 2 setvcp 6e 40   # green black level (neutral)
ddcutil --display 2 setvcp 70 45   # blue black level (increase for less blue in blacks)
ddcutil --display 2 setvcp 14 0x05 # 6500K
