#!/usr/bin/env bash
# share-screenshot — capture via grimshot, resize via vips,
# upload to MicroBin, copy the URL.  Also drops a copy in ~/stash/screenshots/.
#
# Usage:   share-screenshot [grimshot-mode] [edit]
# Modes:   anything (default) | active | area | output | window
# Edit:    pass `edit' as 2nd arg to crop/redact in satty before sharing;
#          quitting satty without saving cancels the upload.

set -euo pipefail

ARCHIVE_DIR="${SHARE_ARCHIVE_DIR:-$HOME/Pictures/screenshots}"
STASH_DIR="${SHARE_STASH_DIR:-$HOME/stash/screenshots}"
MICROBIN_URL="${MICROBIN_URL:-https://share.glvortex.net/upload}"
PASS_ENTRY="${MICROBIN_PASS_ENTRY:-homelab/microbin/uploader}"
GRIMSHOT_MODE="${1:-anything}"
EDIT_MODE="${2:-}"

mkdir -p "$ARCHIVE_DIR" "$STASH_DIR"

TS=$(date -u '+%Y%m%dT%H%M%S')
STEM="${TS}--screenshot-shared__"
PNG="$ARCHIVE_DIR/${STEM}.png"
WEBP="$STASH_DIR/${STEM}.webp"

if ! grimshot save "$GRIMSHOT_MODE" "$PNG"; then
  notify-send "Screenshot canceled"
  exit 0
fi

# Optional interactive crop/redact in satty before sharing.  satty only
# writes the --edited.png on a save action, so quitting without saving
# leaves it absent → cancel the upload.  (The raw capture stays in the
# local archive; only what you upload is gated.)
if [[ "$EDIT_MODE" == edit ]]; then
  EDITED="${PNG%.png}--edited.png"
  # `--default-fill-shapes' makes the rectangle tool draw a SOLID opaque
  # box — the only safe way to redact secrets (blur/pixelate are
  # recoverable, e.g. via Depix).  Use rectangle for passwords; crop is
  # the startup tool for the common "keep this region" case.
  satty -f "$PNG" -o "$EDITED" --early-exit --initial-tool crop \
        --default-fill-shapes \
        --actions-on-enter save-to-file --actions-on-escape exit
  if [[ ! -f "$EDITED" ]]; then
    notify-send "Edit discarded — not uploaded"
    exit 0
  fi
  PNG="$EDITED"
fi

# Resize + strip metadata to the stash dir (so containers see it too).
vips thumbnail "$PNG" "${WEBP}[Q=80,strip]" 1920 --height 1200 --size down

notify-send "Screenshot saved, uploading…" "$(basename "$WEBP")"

PW=$(pass show "$PASS_ENTRY")

REDIRECT=$(curl --silent --show-error \
  --output /dev/null \
  --write-out '%{redirect_url}' \
  --form-string "uploader_password=$PW" \
  -F "file=@${WEBP};type=image/webp;filename=${STEM}.webp" \
  "$MICROBIN_URL") || {
    notify-send "Upload failed" "curl exit $?"
    exit 1
}

case "$REDIRECT" in
  */upload/*)
    URL="${REDIRECT/\/upload\//\/file\/}"
    printf '%s' "$URL" | wl-copy
    notify-send "URL copied" "$URL"
    ;;
  */incorrect)
    notify-send "Upload rejected" "Check $PASS_ENTRY"
    exit 1
    ;;
  *)
    notify-send "Upload failed" "Unexpected: ${REDIRECT:-empty}"
    exit 1
    ;;
esac
