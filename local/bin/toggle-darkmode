#!/bin/env sh

# THEME_LIGHT="catppuccin-latte"
# THEME_DARK="catppuccin-mocha"
THEME_LIGHT="bergheim-light"
THEME_DARK="bergheim-dark"
ALACRITTYCONF="${XDG_CONFIG_HOME}/alacritty/alacritty.toml"
FOOT_CONF="${XDG_CONFIG_HOME}/foot/foot.ini"
BATCONF="${XDG_CONFIG_HOME}/bat/config"
TMUXCONF="${HOME}/.tmux.conf"
WAYBARCONF="${XDG_CONFIG_HOME}/waybar/config"
XRES="${HOME}/.Xresources"
XSETTINGS="${HOME}/.config/xsettingsd/xsettingsd.conf"
QT_THEME="${XDG_CONFIG_HOME}/qt5ct/qt5ct.conf"
QT6_THEME="${XDG_CONFIG_HOME}/qt6ct/qt6ct.conf"

CURRENT_MODE=$(gsettings get org.gnome.desktop.interface color-scheme)

pkill -USR1 -x foot

if [ "$CURRENT_MODE" = "'prefer-dark'" ]; then
    ln -sfn ~/Pictures/wallpapers/active/light ~/Pictures/wallpapers/active/current
    if [[ -z "$WAYLAND_DISPLAY" ]]; then
        feh --bg-fill ~/Pictures/wallpapers/active/light/primary.jpg --bg-fill ~/Pictures/wallpapers/active/light/secondary.jpg &
    fi
    emacsclient -e '(bergheim/theme-light)' &
    gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
    gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"
    # gsettings set org.freedesktop.appearance color-scheme "prefer-light"

    sed -i "/Net\/ThemeName/cNet\/ThemeName \"Adwaita\"" "${XSETTINGS}"
    sed -i "s/initial-color-theme=dark/initial-color-theme=light/" "$FOOT_CONF"
    sed -i "s/${THEME_DARK}/${THEME_LIGHT}/" "$XRES"
    if [ -f "$QT_THEME" ]; then
        sed -i "/^color_scheme_path=/ccolor_scheme_path=/usr/share/qt5ct/colors/airy.conf" $QT_THEME
        sed -i "/^color_scheme_path=/ccolor_scheme_path=/usr/share/qt6ct/colors/airy.conf" $QT6_THEME
    fi
    ln -sf /usr/share/color-schemes/BreezeLight.colors ~/.config/kdeglobals

    ln -sf ~/.config/bat/themes/bergheim-light.tmTheme ~/.config/bat/themes/bergheim-theme.tmTheme
    ln -sf ~/.config/alacritty/colors/bergheim-light.toml ~/.config/alacritty/colors/bergheim-theme.toml
    ln -sf ~/.config/tmux/bergheim-light.conf ~/.config/tmux/bergheim-theme.conf
    ln -sf ~/.config/fuzzel/bergheim-light.ini ~/.config/fuzzel/colors.ini
    ln -sf ~/.config/sway/colors-light ~/.config/sway/colors
    ln -sf ~/.config/mako/config-light ~/.config/mako/config
    [ -n "$WAYLAND_DISPLAY" ] && swaymsg reload >/dev/null 2>&1
    if pgrep -x "dunst" >/dev/null; then
        dunstctl reload ~/.config/dunst/dunstrc &
    fi
    pgrep -x mako >/dev/null && makoctl reload &
else
    ln -sfn ~/Pictures/wallpapers/active/dark ~/Pictures/wallpapers/active/current
    if [[ -z "$WAYLAND_DISPLAY" ]]; then
        feh --bg-fill ~/Pictures/wallpapers/active/dark/primary.jpg --bg-fill ~/Pictures/wallpapers/active/dark/secondary.jpg &
    fi
    emacsclient -e '(bergheim/theme-dark)' &
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
    gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
    # gsettings set org.freedesktop.appearance color-scheme "prefer-dark"

    sed -i "/Net\/ThemeName/cNet\/ThemeName \"Adwaita-dark\"" "${XSETTINGS}"
    sed -i "s/initial-color-theme=light/initial-color-theme=dark/" "$FOOT_CONF"
    sed -i "s/${THEME_LIGHT}/${THEME_DARK}/" "$XRES" "$BATCONF"
    if [ -f "$QT_THEME" ]; then
        sed -i "/^color_scheme_path=/ccolor_scheme_path=/usr/share/qt5ct/colors/darker.conf" $QT_THEME
        sed -i "/^color_scheme_path=/ccolor_scheme_path=/usr/share/qt6ct/colors/darker.conf" $QT6_THEME
    fi
    ln -sf /usr/share/color-schemes/BreezeDark.colors ~/.config/kdeglobals

    ln -sf ~/.config/bat/themes/bergheim-dark.tmTheme ~/.config/bat/themes/bergheim-theme.tmTheme
    ln -sf ~/.config/alacritty/colors/bergheim-dark.toml ~/.config/alacritty/colors/bergheim-theme.toml
    ln -sf ~/.config/tmux/bergheim-dark.conf ~/.config/tmux/bergheim-theme.conf
    ln -sf ~/.config/fuzzel/bergheim-dark.ini ~/.config/fuzzel/colors.ini
    ln -sf ~/.config/sway/colors-dark ~/.config/sway/colors
    ln -sf ~/.config/mako/config-dark ~/.config/mako/config
    [ -n "$WAYLAND_DISPLAY" ] && swaymsg reload >/dev/null 2>&1
    if pgrep -x "dunst" >/dev/null; then
        dunstctl reload ~/.config/dunst/dunstrc_dark &
    fi
    pgrep -x mako >/dev/null && makoctl reload &
fi

# update any running vim instances
for SERVER_PIPE in $(
    shopt -s nullglob
    echo "$XDG_RUNTIME_DIR/nvim.*.0" "/tmp/nvim.$USER/*/nvim.*.0"
); do
    nvim --server "$SERVER_PIPE" --remote-send ':lua dark_light_theme()<cr>' 2>/dev/null
done

xrdb -merge ~/.Xresources
pkill -HUP xsettingsd &
tmux source-file "$TMUXCONF" &
pkill -USR1 polybar &
pgrep -x i3 >/dev/null && i3-msg reload >/dev/null &
